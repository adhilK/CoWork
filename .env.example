# ─── App ──────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="CoWork Pro"

# ─── Supabase ─────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Get this from Supabase → Settings → Database → Connection String → URI
# Use the "Transaction" pooler connection string (port 6543) for serverless

DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Tap Payments (GCC member billing — UAE/KSA/KW/BH) ───────────────────────
# Get from: https://dashboard.tap.company → Developers → API Keys
# Tap is the primary payment gateway for member invoices (NOT platform billing)

TAP_SECRET_KEY=sk_test_...
TAP_PUBLIC_KEY=pk_test_...
# Webhook secret: set in Tap Dashboard → Developers → Webhooks → endpoint secret
TAP_WEBHOOK_SECRET=

# ─── Encryption (AES-256-CBC for PII at rest) ────────────────────────────────
# Required for storing passport numbers, Emirates IDs, Iqama numbers encrypted.
# Generate a 32-byte key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Without this key set, encryption is a no-op (dev only — always set in production).

ENCRYPTION_KEY=

# ─── WhatsApp Business API (Meta Cloud API) ──────────────────────────────────
# Platform-level fallback credentials. Per-org credentials are stored encrypted in
# the WhatsAppConfig table and take precedence over these. Get from:
# Meta Business → WhatsApp → API Setup.
# Optional — operators can connect their own number under Dashboard → WhatsApp → Settings.

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Verify token: any secret string; must match what you enter in the Meta webhook config
WHATSAPP_VERIFY_TOKEN=

# ─── Stripe Atlas (platform billing — operator subscriptions, USD) ───────────
# Not yet implemented — add keys here when Stripe Atlas billing is wired up
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email (Resend) ───────────────────────────────────────────────────────────

RESEND_API_KEY=re_...
EMAIL_FROM="CoWork Pro <noreply@coworkpro.io>"

# ─── Google OAuth (configured in Supabase Auth dashboard) ────────────────────
# No app-level env vars needed — configure in Supabase Auth → Providers → Google

# Cron protection
CRON_SECRET=
