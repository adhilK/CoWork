# ─── App ──────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Maktaby"
NEXT_PUBLIC_APP_VERSION=0.1.0

# ─── Sentry (error monitoring) ───────────────────────────────────────────────
# Get DSN from: Sentry Dashboard → your project → Settings → Client Keys (DSN)
# Sentry is disabled in development (NODE_ENV !== production) — safe to leave
# blank locally. Required in Vercel production env for error alerting.
# NEXT_PUBLIC_ prefix is intentional: the DSN is public (client-side SDK uses it).
NEXT_PUBLIC_SENTRY_DSN=
# Sentry org/project slugs for source-map uploads during build.
# Get from: Sentry Dashboard → Settings → General → Organization Slug / Project Slug
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token for source-map upload (build-time only, never exposed at runtime).
# Create at: Sentry → Settings → Auth Tokens → Create New Token (project:releases + org:read)
SENTRY_AUTH_TOKEN=

# ─── Supabase ─────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Get this from Supabase → Settings → Database → Connection String → URI
# Use the "Transaction" pooler connection string (port 6543) for serverless

DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Moyasar (KSA secondary gateway — Mada + STC Pay) ───────────────────────
# Use when org.paymentProvider = MOYASAR (better Mada/STC Pay coverage in KSA).
# Get from: https://dashboard.moyasar.com → Developers → API Keys
# Sandbox base URL is https://api.moyasar.com — same URL, sandbox key selects sandbox mode.

MOYASAR_API_KEY=sk_test_...
MOYASAR_PUBLISHABLE_KEY=pk_test_...
# Webhook secret: set in Moyasar Dashboard → Developers → Webhooks
MOYASAR_WEBHOOK_SECRET=

# ─── Tap Payments (GCC member billing — UAE/KSA/KW/BH) ───────────────────────
# Get from: https://dashboard.tap.company → Developers → API Keys
# Tap is the primary payment gateway for member invoices (NOT platform billing)

TAP_SECRET_KEY=sk_test_...
TAP_PUBLIC_KEY=pk_test_...
# Webhook secret: set in Tap Dashboard → Developers → Webhooks → endpoint secret
TAP_WEBHOOK_SECRET=

# ─── Encryption (AES-256-CBC for PII at rest) ────────────────────────────────
# Required for storing passport numbers, Emirates IDs, Iqama numbers encrypted.
# Generate a 32-byte key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Without this key set, encryption is a no-op (dev only — always set in production).

ENCRYPTION_KEY=
# Key version label embedded in new ciphertext (increment on rotation, e.g. "1" → "2")
ENCRYPTION_KEY_VERSION=1
# Previous key — set during the rotation window so decryptWithFallback() can read old records.
# Remove after running scripts/rotate-encryption-key.ts completes successfully.
ENCRYPTION_KEY_PREVIOUS=

# ─── WhatsApp Business API (Meta Cloud API) ──────────────────────────────────
# Platform-level fallback credentials. Per-org credentials are stored encrypted in
# the WhatsAppConfig table and take precedence over these. Get from:
# Meta Business → WhatsApp → API Setup.
# Optional — operators can connect their own number under Dashboard → WhatsApp → Settings.

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Verify token: any secret string; must match what you enter in the Meta webhook config
WHATSAPP_VERIFY_TOKEN=

# ─── ZATCA e-invoicing via Wafeq (KSA) ──────────────────────────────────────
# Phase 1 (QR generation) needs NO env — computed locally.
# Phase 2 (reporting/clearance) uses Wafeq, a ZATCA-certified middleware.
# Without WAFEQ_API_KEY the system works normally; invoices stay PENDING.
# Get your API key from: https://app.wafeq.com → Settings → API Keys
#
WAFEQ_API_KEY=
# "simulation" (default) for testing in the ZATCA sandbox; "production" to go live.
ZATCA_ENV=simulation

# ─── Dodo Payments (platform billing — operator subscriptions, Merchant of Record) ──
# Dodo Payments handles recurring billing for operator subscriptions without
# requiring a UAE trade license. Get keys from: https://dashboard.dodopayments.com
# Set DODO_MODE=live when going live (default: test).

DODO_API_KEY=
DODO_WEBHOOK_SECRET=
DODO_MODE=test

# Product IDs: create 3 subscription products priced in USD in the Dodo Dashboard → Products.
# Enable "Adaptive Currency" on each product so customers see AED/SAR at checkout.
# Paste the product IDs (prod_...) here.
DODO_PRODUCT_STARTER=
DODO_PRODUCT_GROWTH=
DODO_PRODUCT_BUSINESS=

# ─── Stripe Atlas (platform billing — operator subscriptions, USD) ───────────
# Not yet implemented — superseded by Dodo Payments above
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email (Resend) ───────────────────────────────────────────────────────────

RESEND_API_KEY=re_...
EMAIL_FROM="Maktaby <noreply@maktaby.io>"

# ─── Google OAuth (configured in Supabase Auth dashboard) ────────────────────
# No app-level env vars needed — configure in Supabase Auth → Providers → Google

# Cron protection (Vercel Cron fallback for billing + reminders)
CRON_SECRET=

# ─── Background jobs (Inngest) ───────────────────────────────────────────────
# Primary job runner: scheduled billing/reminders + WhatsApp/ZATCA queues.
# Get keys from https://app.inngest.com → your app → Keys.
# Without these, the app falls back to Vercel Cron + inline sends (still works).

INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Reminder tuning (days). Remind this many days before expiry; suppress repeats
# within the dedupe window. Defaults: 30 / 14.
REMINDER_DAYS=30
REMINDER_DEDUPE_DAYS=14

# ─── Data retention (PDPL) ───────────────────────────────────────────────────
# Number of days to retain visitor logs before soft-deletion. Default: 90.
# Reduce for stricter PDPL compliance; increase only with a documented legal basis.
VISITOR_CLEANUP_DAYS=90
