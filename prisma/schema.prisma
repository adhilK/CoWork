// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Jurisdiction {
  UAE
  KSA
}

// PDPL consent types (UAE PDPL + Saudi Arabia PDPL)
enum ConsentType {
  DATA_PROCESSING  // mandatory — processing personal data
  MARKETING        // optional — marketing communications
  COOKIES          // optional — non-essential cookies
}

enum PaymentProvider {
  TAP      // Tap Payments — primary GCC gateway (UAE + KSA + KW + BH)
  MOYASAR  // Moyasar — KSA secondary, best Mada / STC Pay coverage
}

enum Plan {
  STARTER
  GROWTH
  PRO
  ENTERPRISE
}

enum UserRole {
  OWNER        // full access incl. billing & settings
  ADMIN        // full operational access, no billing
  MANAGER      // location-level operational access (Phase 3)
  RECEPTIONIST // visitor check-in + booking view only (Phase 3)
  PRO_AGENT    // PRO-services & business-setup workflow only (Phase 3)
  MEMBER       // end-member self-service portal
}

enum ResourceType {
  HOT_DESK
  DEDICATED_DESK
  PRIVATE_OFFICE
  MEETING_ROOM
  EVENT_SPACE
  PHONE_BOOTH
  PODCAST_ROOM
  OTHER
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum PlanType {
  DAY_PASS
  HOT_DESK
  DEDICATED_DESK
  PRIVATE_OFFICE
  VIRTUAL_OFFICE
  CUSTOM
}

enum BillingCycle {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PlatformSubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum VirtualAddressType {
  MAINLAND
  FREEZONE
  OFFSHORE
  PREMIUM_BUSINESS_DISTRICT
}

enum VirtualOfficeStatus {
  ACTIVE
  PENDING_RENEWAL
  EXPIRED
  CANCELLED
}

enum MailType {
  LETTER
  PACKAGE
  LEGAL_DOCUMENT
  GOVERNMENT_CORRESPONDENCE
  COURIER
  OTHER
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum WhatsAppMessageType {
  BOOKING_CONFIRMATION
  BOOKING_REMINDER
  INVOICE_ISSUED
  INVOICE_PAID
  VISITOR_ARRIVAL
  DOCUMENT_EXPIRY
  BUSINESS_SETUP_UPDATE
  PRO_SERVICE_UPDATE
  MAIL_RECEIVED
  RENEWAL_REMINDER
  PAYMENT_REMINDER
  ANNOUNCEMENT
  SUPPORT_MESSAGE
  CUSTOM
}

enum WhatsAppStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

// Maps to Meta's template category taxonomy.
enum WhatsAppTemplateCategory {
  UTILITY
  MARKETING
  AUTHENTICATION
}

// Local approval-tracking mirror of Meta's template review state.
enum WhatsAppTemplateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
  CANCELLED
}

enum DocumentType {
  PASSPORT
  EMIRATES_ID
  IQAMA
  VISA
  TRADE_LICENSE
  EJARI
  ESTABLISHMENT_CARD
  SHARE_CERTIFICATE
  MOA
  AOA
  BANK_STATEMENT
  INSURANCE_CERTIFICATE
  POWER_OF_ATTORNEY
  TENANCY_CONTRACT
  MEDICAL_FITNESS
  POLICE_CLEARANCE
  DEGREE_CERTIFICATE
  OTHER
}

enum DocumentRequestStatus {
  PENDING
  FULFILLED
  OVERDUE
  CANCELLED
}

// KSA ZATCA e-invoicing lifecycle (Module 10).
// PENDING  — Phase-1 QR generated, awaiting reporting/clearance
// REPORTED — submitted to ZATCA reporting API (simplified invoices)
// CLEARED  — cleared by ZATCA (standard invoices)
// REJECTED — submission rejected / failed
enum ZatcaStatus {
  PENDING
  REPORTED
  CLEARED
  REJECTED
}

enum LeadStage {
  NEW_ENQUIRY
  QUALIFIED
  PROPOSAL_SENT
  DOCUMENTS_COLLECTION
  SUBMITTED_TO_AUTHORITY
  AWAITING_APPROVAL
  APPROVED
  COMPLETED
  LOST
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LeadActivityType {
  NOTE
  CALL
  WHATSAPP
  EMAIL
  MEETING
  STAGE_CHANGE
  DOCUMENT_RECEIVED
  PAYMENT_RECEIVED
  PROPOSAL_SENT
  REMINDER_SENT
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

// PRO Services Tracker (Module 7)
enum ProServiceType {
  UAE_VISA_NEW
  UAE_VISA_RENEWAL
  UAE_VISA_CANCELLATION
  UAE_EMIRATES_ID_NEW
  UAE_EMIRATES_ID_RENEWAL
  UAE_ESTABLISHMENT_CARD
  UAE_ECHANNEL_REGISTRATION
  UAE_MEDICAL_FITNESS
  UAE_GDRFA_SERVICE
  UAE_DED_TRANSACTION
  UAE_ATTESTATION
  UAE_TYPING_SERVICE
  UAE_EJARI_REGISTRATION
  UAE_TRADE_LICENSE_RENEWAL
  KSA_IQAMA_NEW
  KSA_IQAMA_RENEWAL
  KSA_QIWA_REGISTRATION
  KSA_MUQEEM_REGISTRATION
  KSA_GOSI_REGISTRATION
  KSA_LABOUR_CONTRACT
  KSA_EXIT_REENTRY_VISA
  KSA_DEPENDENT_VISA
  KSA_ATTESTATION
  KSA_MINISTRY_HR_TRANSACTION
  KSA_TRADE_LICENSE_RENEWAL
  DOCUMENT_ATTESTATION
  NOTARISATION
  OTHER
}

enum ProServiceStage {
  SUBMITTED
  DOCUMENTS_PENDING
  DOCUMENTS_RECEIVED
  IN_PROGRESS
  AT_TYPING_CENTRE
  AT_GOVERNMENT
  AWAITING_COLLECTION
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum ServiceUrgency {
  STANDARD
  EXPRESS
  URGENT
}

// Partner network & referral fees (Phase 3)
enum PartnerType {
  INDIVIDUAL
  COMPANY
  AGENCY
  FREELANCER
  OTHER
}

enum CommissionType {
  PERCENTAGE
  FIXED
}

enum ReferralStatus {
  PENDING
  CONVERTED
  PAID
  CANCELLED
}

// Coarse license classification (Module 6). Detailed products live in
// LicenseCatalog; leads/applications reference this enum.
enum LicenseType {
  UAE_MAINLAND_DED
  UAE_FREEZONE
  UAE_OFFSHORE_RAKICC
  UAE_OFFSHORE_JAFZA
  UAE_BRANCH_OFFICE
  KSA_MAINLAND_MISA
  KSA_SEZ_KAFD
  KSA_SEZ_JAZAN
  KSA_SEZ_NEOM
  KSA_BRANCH_OFFICE
  KSA_REPRESENTATIVE_OFFICE
}

// ─── MULTI-TENANCY ────────────────────────────────────────────────────────────

model Organization {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  logo          String?
  address       String?
  phone         String?
  email         String?
  website       String?
  timezone      String   @default("UTC")
  currency      String   @default("AED")
  // UAE TRN / KSA VAT number — printed on tax invoices (mandatory for VAT-registered entities)
  taxRegistrationNumber String?
  // GCC primary jurisdiction — drives VAT rate, license catalogs, gov bodies.
  // Fuller multi-jurisdiction config lives in JurisdictionConfig.
  jurisdiction      Jurisdiction      @default(UAE)
  // Payment gateway selection. Defaults to Tap (works UAE + KSA).
  // Set to MOYASAR for KSA orgs that want Mada / STC Pay as primary.
  paymentProvider   PaymentProvider   @default(TAP)
  // Onboarding capture (Step 1 of the setup wizard)
  businessType      String?  // Coworking Space | Business Center | Serviced Offices | Mixed Use
  whatsappNumber    String?  // primary WhatsApp contact captured at onboarding
  // Payment setup (Step 5 of the setup wizard). API keys encrypted at rest via lib/encryption.ts.
  tapSecretKey        String?  // encrypted Tap secret key (per-org override of env)
  moyasarApiKey       String?  // encrypted Moyasar key (KSA Mada / STC Pay)
  bankTransferDetails Json?    // { bankName, iban, accountName }
  // Wafeq / ZATCA Phase-2 onboarding (Module 10)
  wafeqAccountId String?  // Wafeq connected account ID (wacc_*)
  zatcaDeviceId  String?  // ZATCA device ID registered via Fatoorah portal (zdev_*)
  zatcaCrNumber  String?  // Saudi Commercial Registration number
  zatcaVatNumber String?  // 15-digit Saudi VAT TIN (overrides taxRegistrationNumber for ZATCA)
  zatcaAddress   Json?    // { street, buildingNumber, district, city, postalCode }
  // Multi-location (Module 11)
  allowCrossLocationBooking Boolean @default(true)  // members may book at any location
  franchiseParentId         String?                 // master operator org, if franchised
  plan          Plan     @default(STARTER)
  trialEndsAt   DateTime?
  // @deprecated — superseded by PlatformSubscription.stripeCustomerId
  stripeCustomerId     String?
  // @deprecated — superseded by PlatformSubscription.stripeSubscriptionId
  stripeSubscriptionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users                UserOrganization[]
  locations            Location[]
  resources            Resource[]
  members              Member[]
  bookings             Booking[]
  invoices             Invoice[]
  plans                MembershipPlan[]
  visitors             Visitor[]
  announcements        Announcement[]
  events               Event[]
  jurisdictionConfig        JurisdictionConfig?
  platformSubscription      PlatformSubscription?
  virtualOfficeAddresses    VirtualOfficeAddress[]
  virtualOfficeSubscriptions VirtualOfficeSubscription[]
  mailItems                 MailItem[]
  whatsAppConfig            WhatsAppConfig?
  whatsAppMessages          WhatsAppMessage[]
  whatsAppTemplates         WhatsAppTemplate[]
  whatsAppBroadcasts        WhatsAppBroadcast[]
  documents                 Document[]
  documentRequests          DocumentRequest[]
  deliveries                Delivery[]
  licenseCatalog            LicenseCatalog[]
  businessSetupLeads        BusinessSetupLead[]
  proServiceRequests        ProServiceRequest[]
  partners                  Partner[]
  referrals                 Referral[]
  notifications             Notification[]

  @@index([slug])
}

// ─── JURISDICTION CONFIG (GCC) ────────────────────────────────────────────────
// Per-organization jurisdiction settings. Drives VAT rates, currencies, and
// jurisdiction-specific toggles (ZATCA, Arabic invoices, WhatsApp). Always read
// jurisdiction-derived values via lib/jurisdiction.ts — never hardcode inline.

model JurisdictionConfig {
  id                  String         @id @default(cuid())
  organizationId      String         @unique
  jurisdictions       Jurisdiction[] @default([])   // ['UAE'], ['KSA'], or both
  primaryJurisdiction Jurisdiction   @default(UAE)
  vatRateUAE          Decimal        @default(0.05) @db.Decimal(5, 4)  // 5%
  vatRateKSA          Decimal        @default(0.15) @db.Decimal(5, 4)  // 15%
  currencyUAE         String         @default("AED")
  currencyKSA         String         @default("SAR")
  zatcaEnabled        Boolean        @default(false)  // KSA only
  arabicInvoices      Boolean        @default(false)
  whatsappEnabled     Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// Tracks the operator's CoWork Pro platform subscription (Dodo Payments MoR).
// Created at TRIAL on org registration; upgraded to ACTIVE via Dodo webhook.
model PlatformSubscription {
  id                   String                     @id @default(cuid())
  organizationId       String                     @unique
  status               PlatformSubscriptionStatus @default(TRIAL)
  plan                 Plan
  // Billing currency derived from org jurisdiction (UAE → AED, KSA → SAR).
  currency             String                     @default("AED")
  // Monthly fee in local currency — null until operator upgrades from trial.
  monthlyFee           Decimal?                   @db.Decimal(10, 2)
  // @deprecated — superseded by Dodo fields below
  stripeCustomerId     String?
  stripeSubscriptionId String?
  // Dodo Payments (Merchant of Record — no UAE trade license required)
  dodoCustomerId       String?
  dodoSubscriptionId   String?
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  organization         Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// Idempotency log for incoming webhook events (prevents double-processing).
model ProcessedWebhook {
  webhookId   String
  source      String   // "dodo" | "tap" | "moyasar"
  processedAt DateTime @default(now())

  @@id([webhookId, source])
}

// In-app notifications shown in the dashboard bell icon.
// Created by webhooks (plan activated, payment failed) and system events.
model Notification {
  id             String    @id @default(cuid())
  organizationId String
  type           String    // "PLAN_ACTIVATED" | "PAYMENT_FAILED" | "TRIAL_ENDING" | etc.
  title          String
  body           String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, readAt])
}

// ─── USERS & AUTH ─────────────────────────────────────────────────────────────
// Note: Supabase Auth manages authentication.
// This User model mirrors the Supabase auth.users table for relational data.

model User {
  id           String   @id // matches Supabase auth.users.id (UUID)
  email        String   @unique
  name         String?
  avatar       String?
  isSuperAdmin Boolean  @default(false)
  // Google Calendar integration
  googleCalendarRefreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organizations UserOrganization[]
  bookings      Booking[]
  member        Member?

  @@index([email])
}

model UserOrganization {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           UserRole     @default(MEMBER)
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

// ─── LOCATIONS ────────────────────────────────────────────────────────────────

model Location {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  address        String?
  floorPlanUrl   String?
  isActive       Boolean      @default(true)
  // Multi-location & franchise (Module 11)
  jurisdiction       Jurisdiction @default(UAE)
  city               String?
  country            String?
  timezone           String?    // overrides org timezone for this location
  phone              String?
  email              String?
  vatNumber          String?    // KSA requires per-branch VAT registration
  managerUserId      String?    // operator user who manages this location
  openingHours       Json?      // { mon: { open, close, closed }, ... }
  accessInstructions String?    // shown to members (how to get in)
  wifiName           String?
  wifiPassword       String?    // encrypted at rest (lib/encryption.ts)
  parentLocationId   String?    // franchise sub-location → parent
  deletedAt          DateTime?  // soft delete
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  resources      Resource[]

  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([organizationId, deletedAt])
}

// ─── RESOURCES ────────────────────────────────────────────────────────────────

model Resource {
  id                  String       @id @default(cuid())
  organizationId      String
  locationId          String
  name                String
  type                ResourceType
  description         String?
  capacity            Int          @default(1)
  hourlyRate          Decimal?     @db.Decimal(10, 2)
  halfDayRate         Decimal?     @db.Decimal(10, 2)
  fullDayRate         Decimal?     @db.Decimal(10, 2)
  monthlyRate         Decimal?     @db.Decimal(10, 2)
  amenities           String[]
  images              String[]
  isActive            Boolean      @default(true)
  requiresApproval    Boolean      @default(false)
  advanceBookingDays  Int          @default(30)
  minBookingMinutes   Int          @default(30)
  maxBookingHours     Int          @default(8)
  // Public / external booking
  externalBookingEnabled Boolean   @default(false)
  externalHourlyRate     Decimal?  @db.Decimal(10, 2)
  // Soft delete
  deletedAt           DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location       Location     @relation(fields: [locationId], references: [id])
  bookings       Booking[]

  @@index([organizationId])
  @@index([locationId])
  @@index([organizationId, deletedAt])
}

// ─── MEMBERSHIP PLANS ─────────────────────────────────────────────────────────

model MembershipPlan {
  id              String       @id @default(cuid())
  organizationId  String
  name            String
  description     String?
  type            PlanType
  price           Decimal      @db.Decimal(10, 2)
  billingCycle    BillingCycle @default(MONTHLY)
  includedCredits Int          @default(0)
  meetingRoomHours Int         @default(0)
  features        String[]
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        Member[]

  @@index([organizationId])
}

// ─── MEMBERS ─────────────────────────────────────────────────────────────────

model Member {
  id               String         @id @default(cuid())
  organizationId   String
  userId           String         @unique
  membershipPlanId String?
  status           MemberStatus   @default(ACTIVE)
  startDate        DateTime       @default(now())
  endDate          DateTime?
  credits          Int            @default(0)
  notes            String?
  company          String?
  jobTitle         String?
  bio              String?
  phone            String?
  // GCC fields
  whatsAppNumber   String?        // WhatsApp number for automated messaging
  // Communication preferences (member portal → Profile)
  language         String         @default("en")  // Preferred language: en | ar
  notifyByEmail    Boolean        @default(true)   // Opt-in to email notifications
  notifyByWhatsApp Boolean        @default(true)   // Opt-in to WhatsApp notifications
  nationality      String?        // ISO country code or name
  passportNumber   String?        // Encrypted at rest via lib/encryption.ts
  emiratesId       String?        // UAE Emirates ID — encrypted at rest
  iqamaNumber      String?        // KSA Iqama number — encrypted at rest
  visaExpiry       DateTime?      // Visa/residency expiry — drives renewal reminders
  // PDPL right to erasure — set when PII is anonymized
  erasedAt         DateTime?
  // Soft delete
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  organization              Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                      User            @relation(fields: [userId], references: [id])
  membershipPlan            MembershipPlan? @relation(fields: [membershipPlanId], references: [id])
  bookings                  Booking[]
  invoices                  Invoice[]
  virtualOfficeSubscriptions VirtualOfficeSubscription[]
  whatsAppMessages          WhatsAppMessage[]
  documents                 Document[]
  documentRequests          DocumentRequest[]
  deliveries                Delivery[]
  businessSetupLeads        BusinessSetupLead[]
  proServiceRequests        ProServiceRequest[]

  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, status])
}

// ─── BOOKINGS ────────────────────────────────────────────────────────────────

model Booking {
  id               String        @id @default(cuid())
  organizationId   String
  resourceId       String
  memberId         String?
  userId           String
  title            String?
  description      String?
  startTime        DateTime
  endTime          DateTime
  status           BookingStatus @default(CONFIRMED)
  creditsUsed      Int           @default(0)
  amountCharged    Decimal       @default(0) @db.Decimal(10, 2)
  invoiceId        String?       // set when booking is added to an invoice
  attendees        Int           @default(1)
  externalGuests   String[]
  checkedInAt      DateTime?
  checkedOutAt     DateTime?
  cancelledAt      DateTime?
  cancelReason     String?
  isRecurring      Boolean       @default(false)
  recurringGroupId String?
  // Google Calendar
  googleCalendarEventId String?
  // Soft delete
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  resource       Resource     @relation(fields: [resourceId], references: [id])
  member         Member?      @relation(fields: [memberId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  invoice        Invoice?     @relation(fields: [invoiceId], references: [id])

  @@index([organizationId])
  @@index([resourceId])
  @@index([memberId])
  @@index([organizationId, startTime, endTime])
  @@index([resourceId, status])
  @@index([organizationId, status])
  @@index([organizationId, deletedAt])
}

// ─── INVOICES ────────────────────────────────────────────────────────────────

model Invoice {
  id              String        @id @default(cuid())
  organizationId  String
  memberId        String
  invoiceNumber   String?       // e.g. INV-2024-001
  // @deprecated — Stripe no longer used for member billing (use tapChargeId)
  stripeInvoiceId String?
  // @deprecated — Stripe no longer used for member billing
  stripePaymentLinkId String?
  tapChargeId       String?   // Tap charge ID
  moyasarPaymentId  String?   // Moyasar payment ID (KSA / Mada / STC Pay)
  moyasarCheckoutUrl String?  // Moyasar hosted checkout URL (cached; regenerate after 24h)
  // Overdue reminder tracking — stops auto-reminders after max attempts.
  remindersSent     Int       @default(0)
  lastReminderAt    DateTime?
  // @deprecated — superseded by the subtotal/vatAmount/totalAmount breakdown
  // below. Retained for transition + backfill; kept equal to `totalAmount`.
  // Do not read for new code — use `totalAmount`.
  amount          Decimal       @db.Decimal(10, 2)
  // VAT-compliant money breakdown (GCC). subtotal is VAT-exclusive; VAT is
  // applied on top per the org's jurisdiction; totalAmount = subtotal + vatAmount.
  subtotal        Decimal       @default(0) @db.Decimal(10, 2)
  vatRate         Decimal       @default(0) @db.Decimal(5, 4)  // e.g. 0.05 UAE, 0.15 KSA
  vatAmount       Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal       @default(0) @db.Decimal(10, 2)
  currency        String        @default("AED")
  status          InvoiceStatus @default(DRAFT)
  dueDate         DateTime
  paidAt          DateTime?
  periodStart     DateTime?
  periodEnd       DateTime?
  lineItems       Json          // [{ description, quantity, unitPrice, total }]
  notes           String?
  virtualOfficeSubscriptionId String?
  // ZATCA e-invoicing (KSA only — null for UAE / non-VAT invoices)
  zatcaUuid       String?       // invoice UUID (Phase 2)
  zatcaHash       String?       // invoice hash / PIH placeholder
  zatcaQrCode     String?       // Phase-1 TLV QR, base64 (ZATCA-compliant)
  zatcaStatus     ZatcaStatus?
  zatcaReportedAt DateTime?
  wafeqInvoiceId  String?   // Wafeq invoice ID returned after submission (zinv_*)
  // Soft delete
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization              Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member                    Member                     @relation(fields: [memberId], references: [id])
  bookings                  Booking[]
  virtualOfficeSubscription VirtualOfficeSubscription? @relation(fields: [virtualOfficeSubscriptionId], references: [id])

  @@index([organizationId])
  @@index([memberId])
  @@index([organizationId, status])
  @@index([dueDate])
  @@index([organizationId, deletedAt])
}

// ─── VISITORS ────────────────────────────────────────────────────────────────

model Visitor {
  id              String    @id @default(cuid())
  organizationId  String
  name            String
  email           String?
  phone           String?
  company         String?
  hostMemberId    String?
  purpose         String?
  expectedArrival DateTime?
  checkedInAt     DateTime?
  checkedOutAt    DateTime?
  // GCC / reception (Module 9)
  nationality     String?
  idType          String?   // "Passport" | "Emirates ID" | "Iqama"
  idNumber        String?   // encrypted at rest (lib/encryption.ts)
  vehiclePlate    String?
  photoUrl        String?   // private bucket object path — served via signed URL
  isBlacklisted   Boolean   @default(false)
  blacklistReason String?
  whatsappNotified Boolean  @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, checkedInAt])
  @@index([organizationId, deletedAt])
  @@index([organizationId, isBlacklisted])
}

// ─── DELIVERIES (reception) ─────────────────────────────────────────────────
// Packages/mail received at reception for members (distinct from the Virtual
// Office mailroom, which is for registered-address clients).

model Delivery {
  id             String    @id @default(cuid())
  organizationId String
  memberId       String?
  courierName    String?
  trackingNumber String?
  description    String?
  photoUrl       String?
  receivedBy     String?   // staff name
  receivedAt     DateTime  @default(now())
  notifiedAt     DateTime?
  collectedAt    DateTime?
  collectedBy    String?   // who collected (name / signature note)
  whatsappNotified Boolean @default(false)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member         Member?      @relation(fields: [memberId], references: [id])

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, collectedAt])
  @@index([memberId])
}

// ─── LICENSE CATALOG (Business Setup CRM — Module 6) ─────────────────────────────
// Per-org catalog of license/jurisdiction products operators sell. Seeded from a
// built-in UAE template, then customised (pricing, what they offer). Referenced
// by leads/proposals/applications.

model LicenseCatalog {
  id               String       @id @default(cuid())
  organizationId   String
  jurisdiction     Jurisdiction @default(UAE)
  licenseType      LicenseType
  authority        String       // "IFZA", "DMCC", "DET (Dubai)", "RAK ICC" ...
  emirate          String?      // Dubai, Abu Dhabi, Sharjah, RAK, Ajman, UAQ, Fujairah
  name             String       // product/package name
  activityCategory String?      // Commercial, Professional, Industrial, Holding, E-commerce
  description      String?
  // Costs in AED (VAT-exclusive). Operator sets the selling price on a proposal.
  baseCost         Decimal?     @db.Decimal(10, 2)
  govFees          Decimal?     @db.Decimal(10, 2)
  visaQuota        Int?         // visas included / available
  officeType       String?      // Flexi-desk, Physical office, Virtual, None
  minShareCapital  Decimal?     @db.Decimal(12, 2)
  tenureYears      Int          @default(1)
  processingDays   Int?         // estimated turnaround
  features         String[]     @default([])
  isActive         Boolean      @default(true)
  isPopular        Boolean      @default(false)
  // Provenance: distinguishes seeded template rows from operator-custom ones.
  templateKey      String?      // stable key from the seed template (for idempotent import)
  deletedAt        DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, jurisdiction])
  @@index([organizationId, deletedAt])
  @@index([organizationId, licenseType])
}

// ─── BUSINESS SETUP CRM (Module 6) ──────────────────────────────────────────────

model BusinessSetupLead {
  id                String        @id @default(cuid())
  organizationId    String
  memberId          String?       // linked once converted
  assignedTo        String?       // operator userId (PRO agent / staff)
  jurisdiction      Jurisdiction  @default(UAE)
  clientName        String
  clientEmail       String?
  clientPhone       String
  clientWhatsapp    String?
  clientNationality String?
  companyName       String?
  licenseType       LicenseType
  licenseCatalogId  String?       // selected catalog product
  freezoneName      String?       // UAE freezone / authority
  sezName           String?       // KSA SEZ
  businessActivity  String[]      @default([])
  stage             LeadStage     @default(NEW_ENQUIRY)
  priority          LeadPriority  @default(MEDIUM)
  estimatedFee      Decimal?      @db.Decimal(10, 2)
  quotedFee         Decimal?      @db.Decimal(10, 2)
  currency          String        @default("AED")
  notes             String?
  source            String?       // WhatsApp, walk-in, referral, website
  expectedCloseDate DateTime?
  closedAt          DateTime?
  lostReason        String?
  deletedAt         DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  organization      Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member            Member?                   @relation(fields: [memberId], references: [id])
  activities        LeadActivity[]
  proposal          BusinessSetupProposal?
  application        BusinessSetupApplication?

  @@index([organizationId])
  @@index([organizationId, stage])
  @@index([organizationId, deletedAt])
  @@index([assignedTo])
  @@index([memberId])
}

model LeadActivity {
  id           String           @id @default(cuid())
  leadId       String
  userId       String
  activityType LeadActivityType @default(NOTE)
  note         String
  createdAt    DateTime         @default(now())

  lead         BusinessSetupLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model BusinessSetupProposal {
  id             String         @id @default(cuid())
  leadId         String         @unique
  organizationId String
  lineItems      Json           // [{ service, description, fee }]
  subtotal       Decimal        @default(0) @db.Decimal(10, 2)
  totalFee       Decimal        @db.Decimal(10, 2)
  currency       String         @default("AED")
  validUntil     DateTime
  status         ProposalStatus @default(DRAFT)
  notes          String?
  sentAt         DateTime?
  acceptedAt     DateTime?
  pdfUrl         String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  lead           BusinessSetupLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model BusinessSetupApplication {
  id              String       @id @default(cuid())
  leadId          String       @unique
  organizationId  String
  jurisdiction    Jurisdiction
  licenseType     LicenseType
  referenceNumber String?
  authorityName   String?      // DED, RAKEZ, MISA...
  currentStep     String?
  steps           Json         @default("[]")  // [{ step, status, completedAt, notes }]
  submittedAt     DateTime?
  approvedAt      DateTime?
  licenseNumber   String?
  licenseExpiry   DateTime?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  lead            BusinessSetupLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ─── PRO SERVICES TRACKER (Module 7) ────────────────────────────────────────────

model ProServiceRequest {
  id                 String          @id @default(cuid())
  organizationId     String
  memberId           String
  assignedTo         String?         // staff userId (PRO agent)
  jurisdiction       Jurisdiction    @default(UAE)
  serviceType        ProServiceType
  serviceDescription String?
  urgency            ServiceUrgency  @default(STANDARD)
  stage              ProServiceStage @default(SUBMITTED)
  governingBody      String?         // DED, GDRFA, MISA, Qiwa...
  referenceNumber    String?
  requestedBy        String?         // member or operator userId
  fee                Decimal?        @db.Decimal(10, 2)
  currency           String          @default("AED")
  invoiceId          String?         // linked member invoice (plain ref)
  slaDays            Int?
  dueDate            DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancelReason       String?
  clientNotes        String?         // client-visible
  internalNotes      String?         // operator only
  deletedAt          DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  organization       Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member             Member               @relation(fields: [memberId], references: [id])
  activities         ProServiceActivity[]

  @@index([organizationId])
  @@index([organizationId, stage])
  @@index([organizationId, deletedAt])
  @@index([memberId])
  @@index([assignedTo])
  @@index([organizationId, dueDate])
}

model ProServiceActivity {
  id              String           @id @default(cuid())
  requestId       String
  userId          String
  stage           ProServiceStage?
  note            String
  isClientVisible Boolean          @default(true)
  createdAt       DateTime         @default(now())

  request         ProServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

// ─── PARTNER NETWORK & REFERRAL FEES (Phase 3) ──────────────────────────────────

model Partner {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  companyName    String?
  type           PartnerType    @default(INDIVIDUAL)
  email          String?
  phone          String?
  whatsapp       String?
  commissionType CommissionType @default(PERCENTAGE)
  // PERCENTAGE → percent (e.g. 10.00); FIXED → flat amount per converted referral.
  commissionRate Decimal        @default(0) @db.Decimal(10, 2)
  currency       String         @default("AED")
  payoutDetails  String?        // IBAN/bank — encrypted at rest (lib/encryption.ts)
  notes          String?
  isActive       Boolean        @default(true)
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  referrals      Referral[]

  @@index([organizationId])
  @@index([organizationId, deletedAt])
}

model Referral {
  id                 String         @id @default(cuid())
  organizationId     String
  partnerId          String
  clientName         String
  clientPhone        String?
  clientEmail        String?
  serviceDescription String?
  leadId             String?        // linked BusinessSetupLead (plain ref)
  memberId           String?        // when converted to a member
  dealValue          Decimal?       @db.Decimal(10, 2)
  commissionAmount   Decimal?       @db.Decimal(10, 2)
  currency           String         @default("AED")
  status             ReferralStatus @default(PENDING)
  convertedAt        DateTime?
  paidAt             DateTime?
  payoutReference    String?
  notes              String?
  deletedAt          DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  partner            Partner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, deletedAt])
  @@index([partnerId])
}

// ─── COMMUNITY ───────────────────────────────────────────────────────────────

model Announcement {
  id             String       @id @default(cuid())
  organizationId String
  title          String
  body           String
  isPinned       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Event {
  id             String       @id @default(cuid())
  organizationId String
  title          String
  description    String?
  startTime      DateTime
  endTime        DateTime
  location       String?
  capacity       Int?
  imageUrl       String?
  isPublic       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, startTime])
}

// ─── VIRTUAL OFFICE ───────────────────────────────────────────────────────────

model VirtualOfficeAddress {
  id             String             @id @default(cuid())
  organizationId String
  jurisdiction   Jurisdiction       @default(UAE)
  addressLine    String
  addressType    VirtualAddressType @default(MAINLAND)
  freezoneName   String?            // e.g. "DMCC", "DIFC", "ADGM"
  ejariNumber    String?            // UAE: Ejari contract reference
  maxClients     Int                @default(50)
  isActive       Boolean            @default(true)
  monthlyFee     Decimal            @db.Decimal(10, 2)
  // Soft delete
  deletedAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptions  VirtualOfficeSubscription[]
  mailItems      MailItem[]

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, isActive])
}

model VirtualOfficeSubscription {
  id             String              @id @default(cuid())
  organizationId String
  memberId       String
  addressId      String
  companyName    String
  licenseNumber  String?
  licenseExpiry  DateTime?
  startDate      DateTime            @default(now())
  endDate        DateTime?
  renewalDate    DateTime?
  status         VirtualOfficeStatus @default(ACTIVE)
  monthlyFee     Decimal             @db.Decimal(10, 2)
  currency       String              @default("AED")
  notes          String?
  // Soft delete — KSA ZATCA mandates 5-year retention; never hard delete
  deletedAt      DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member         Member               @relation(fields: [memberId], references: [id])
  address        VirtualOfficeAddress @relation(fields: [addressId], references: [id])
  invoices       Invoice[]
  mailItems      MailItem[]

  @@index([organizationId])
  @@index([memberId])
  @@index([addressId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, status])
}

model MailItem {
  id             String                     @id @default(cuid())
  organizationId String
  addressId      String
  subscriptionId String?
  senderName     String?
  senderAddress  String?
  receivedAt     DateTime                   @default(now())
  mailType       MailType                   @default(OTHER)
  description    String?
  trackingNumber String?
  // scanUrl: Supabase Storage object path (not a URL); signed URL generated on read
  scanPath       String?
  forwardedAt    DateTime?
  forwardedTo    String?
  notifiedAt     DateTime?
  collectedAt    DateTime?
  // Soft delete
  deletedAt      DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  organization   Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  address        VirtualOfficeAddress        @relation(fields: [addressId], references: [id])
  subscription   VirtualOfficeSubscription?  @relation(fields: [subscriptionId], references: [id])

  @@index([organizationId])
  @@index([addressId])
  @@index([subscriptionId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, receivedAt])
}

// ─── WHATSAPP BUSINESS API ────────────────────────────────────────────────────
// Per-org WhatsApp Business API credentials. accessToken is encrypted at rest via
// lib/encryption.ts. Falls back to platform-level env vars when no row exists.

model WhatsAppConfig {
  id                String   @id @default(cuid())
  organizationId    String   @unique
  phoneNumberId     String
  accessToken       String   // encrypted at rest (lib/encryption.ts)
  businessAccountId String
  verifyToken       String   // webhook verification challenge token
  displayNumber     String?  // human-readable sender number, e.g. +971 50 000 0000
  isActive          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model WhatsAppMessage {
  id                String              @id @default(cuid())
  organizationId    String
  memberId          String?
  broadcastId       String?
  phone             String              // E.164, no + (Meta format)
  direction         MessageDirection
  messageType       WhatsAppMessageType @default(CUSTOM)
  templateName      String?
  content           String
  mediaUrl          String?
  waMessageId       String?             // Meta message ID (wamid.*)
  status            WhatsAppStatus      @default(SENT)
  sentAt            DateTime            @default(now())
  deliveredAt       DateTime?
  readAt            DateTime?
  failedReason      String?
  relatedEntityType String?             // "booking" | "invoice" | "proservice" ...
  relatedEntityId   String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member            Member?             @relation(fields: [memberId], references: [id])
  broadcast         WhatsAppBroadcast?  @relation(fields: [broadcastId], references: [id])

  @@index([organizationId])
  @@index([memberId])
  @@index([organizationId, status])
  @@index([organizationId, phone])
  @@index([organizationId, sentAt])
  @@index([broadcastId])
  @@index([waMessageId])
}

// Reusable message templates. Mirrors Meta-approved templates plus locally-drafted
// quick replies. Body uses {{1}}, {{2}} positional placeholders (Meta convention).
model WhatsAppTemplate {
  id             String                   @id @default(cuid())
  organizationId String
  name           String                   // Meta template name (snake_case)
  category       WhatsAppTemplateCategory @default(UTILITY)
  language       String                   @default("en")
  body           String
  variables      String[]                 @default([])  // labels for {{1}}, {{2}} ...
  status         WhatsAppTemplateStatus   @default(DRAFT)
  isActive       Boolean                  @default(true)
  deletedAt      DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([organizationId, deletedAt])
}

// A one-to-many broadcast campaign. Each broadcast fans out into WhatsAppMessage
// rows (one per recipient) linked via broadcastId.
model WhatsAppBroadcast {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  templateName   String?         // template used, if any
  content        String          // resolved/preview body
  audienceFilter Json?           // { status?, membershipPlanId?, hasWhatsApp? }
  status         BroadcastStatus @default(DRAFT)
  recipientCount Int             @default(0)
  sentCount      Int             @default(0)
  failedCount    Int             @default(0)
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages       WhatsAppMessage[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, deletedAt])
}

// ─── DOCUMENT VAULT ───────────────────────────────────────────────────────────
// Per-member document storage. Files live in a PRIVATE Supabase bucket; fileUrl
// holds the storage object PATH, never a public URL. Served only via short-lived
// (15-min) signed URLs generated on demand. documentNumber is encrypted at rest.

model Document {
  id                String       @id @default(cuid())
  organizationId    String
  memberId          String
  documentType      DocumentType
  label             String?      // free-text label, esp. for OTHER
  fileUrl           String       // private bucket object path (NOT a public URL)
  fileName          String
  fileSize          Int
  mimeType          String
  expiryDate        DateTime?
  issueDate         DateTime?
  issueCountry      String?
  documentNumber    String?      // encrypted at rest (lib/encryption.ts)
  isVerified        Boolean      @default(false)
  verifiedAt        DateTime?
  verifiedBy        String?      // operator userId who verified
  notes             String?
  version           Int          @default(1)
  previousVersionId String?      // chain to the prior version of this document
  uploadedBy        String?      // userId who uploaded (member or operator)
  uploadedAt        DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?    // soft delete (also used to retire old versions)

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member            Member       @relation(fields: [memberId], references: [id])

  @@index([organizationId])
  @@index([memberId])
  @@index([organizationId, expiryDate])
  @@index([organizationId, deletedAt])
  @@index([memberId, deletedAt])
}

model DocumentRequest {
  id             String                @id @default(cuid())
  organizationId String
  memberId       String
  requestedBy    String                // operator userId
  documentType   DocumentType
  message        String?
  dueDate        DateTime?
  status         DocumentRequestStatus @default(PENDING)
  fulfilledAt    DateTime?
  fulfilledDocId String?               // Document.id that fulfilled the request
  deletedAt      DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member         Member       @relation(fields: [memberId], references: [id])

  @@index([organizationId])
  @@index([memberId])
  @@index([organizationId, status])
  @@index([memberId, status])
}

// ─── PDPL COMPLIANCE ──────────────────────────────────────────────────────────
// UAE Personal Data Protection Law (PDPL) + Saudi Arabia PDPL.

// Append-only consent audit log. The most recent row per (userId, consentType)
// represents the current consent state. Never delete rows — audit trail.
model ConsentLog {
  id             String      @id @default(cuid())
  userId         String      // Supabase auth user ID
  organizationId String?     // null for pre-registration / platform-level consent
  consentType    ConsentType
  consentGiven   Boolean
  ipAddress      String?
  userAgent      String?
  version        String      @default("1.0") // consent policy version

  // Immutable — createdAt IS the consent timestamp. No updatedAt.
  createdAt      DateTime    @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([userId, consentType])
  @@index([createdAt])
}

// Audit trail for right-to-erasure executions (PDPL Art. 17 / UAE PDPL).
// Records who anonymized whom, what fields were cleared, and how many files
// were deleted. Never hard-delete these rows — they are the compliance record.
model DataErasureLog {
  id               String   @id @default(cuid())
  organizationId   String
  memberId         String   // Member.id of the erased record
  userId           String   // User.id that was anonymized
  executedBy       String   // Admin userId who triggered the erasure
  documentsDeleted Int      @default(0)
  fieldsAnonymized String[] // list of field paths cleared for auditability
  notes            String?
  createdAt        DateTime @default(now())

  @@index([organizationId])
  @@index([memberId])
  @@index([createdAt])
}
