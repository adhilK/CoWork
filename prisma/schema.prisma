// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Jurisdiction {
  UAE
  KSA
}

enum Plan {
  STARTER
  GROWTH
  PRO
  ENTERPRISE
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum ResourceType {
  HOT_DESK
  DEDICATED_DESK
  PRIVATE_OFFICE
  MEETING_ROOM
  EVENT_SPACE
  PHONE_BOOTH
  PODCAST_ROOM
  OTHER
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum PlanType {
  DAY_PASS
  HOT_DESK
  DEDICATED_DESK
  PRIVATE_OFFICE
  VIRTUAL_OFFICE
  CUSTOM
}

enum BillingCycle {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PlatformSubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum VirtualAddressType {
  MAINLAND
  FREEZONE
  OFFSHORE
  PREMIUM_BUSINESS_DISTRICT
}

enum VirtualOfficeStatus {
  ACTIVE
  PENDING_RENEWAL
  EXPIRED
  CANCELLED
}

enum MailType {
  LETTER
  PACKAGE
  LEGAL_DOCUMENT
  GOVERNMENT_CORRESPONDENCE
  COURIER
  OTHER
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum WhatsAppMessageType {
  BOOKING_CONFIRMATION
  BOOKING_REMINDER
  INVOICE_ISSUED
  INVOICE_PAID
  VISITOR_ARRIVAL
  DOCUMENT_EXPIRY
  BUSINESS_SETUP_UPDATE
  PRO_SERVICE_UPDATE
  MAIL_RECEIVED
  RENEWAL_REMINDER
  ANNOUNCEMENT
  SUPPORT_MESSAGE
  CUSTOM
}

enum WhatsAppStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

// Maps to Meta's template category taxonomy.
enum WhatsAppTemplateCategory {
  UTILITY
  MARKETING
  AUTHENTICATION
}

// Local approval-tracking mirror of Meta's template review state.
enum WhatsAppTemplateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
  CANCELLED
}

enum DocumentType {
  PASSPORT
  EMIRATES_ID
  IQAMA
  VISA
  TRADE_LICENSE
  EJARI
  ESTABLISHMENT_CARD
  SHARE_CERTIFICATE
  MOA
  AOA
  BANK_STATEMENT
  INSURANCE_CERTIFICATE
  POWER_OF_ATTORNEY
  TENANCY_CONTRACT
  MEDICAL_FITNESS
  POLICE_CLEARANCE
  DEGREE_CERTIFICATE
  OTHER
}

enum DocumentRequestStatus {
  PENDING
  FULFILLED
  OVERDUE
  CANCELLED
}

// KSA ZATCA e-invoicing lifecycle (Module 10).
// PENDING  — Phase-1 QR generated, awaiting reporting/clearance
// REPORTED — submitted to ZATCA reporting API (simplified invoices)
// CLEARED  — cleared by ZATCA (standard invoices)
// REJECTED — submission rejected / failed
enum ZatcaStatus {
  PENDING
  REPORTED
  CLEARED
  REJECTED
}

// ─── MULTI-TENANCY ────────────────────────────────────────────────────────────

model Organization {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  logo          String?
  address       String?
  phone         String?
  email         String?
  website       String?
  timezone      String   @default("UTC")
  currency      String   @default("AED")
  // UAE TRN / KSA VAT number — printed on tax invoices (mandatory for VAT-registered entities)
  taxRegistrationNumber String?
  // GCC primary jurisdiction — drives VAT rate, license catalogs, gov bodies.
  // Fuller multi-jurisdiction config lives in JurisdictionConfig.
  jurisdiction  Jurisdiction @default(UAE)
  // Multi-location (Module 11)
  allowCrossLocationBooking Boolean @default(true)  // members may book at any location
  franchiseParentId         String?                 // master operator org, if franchised
  plan          Plan     @default(STARTER)
  trialEndsAt   DateTime?
  // @deprecated — superseded by PlatformSubscription.stripeCustomerId
  stripeCustomerId     String?
  // @deprecated — superseded by PlatformSubscription.stripeSubscriptionId
  stripeSubscriptionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users                UserOrganization[]
  locations            Location[]
  resources            Resource[]
  members              Member[]
  bookings             Booking[]
  invoices             Invoice[]
  plans                MembershipPlan[]
  visitors             Visitor[]
  announcements        Announcement[]
  events               Event[]
  jurisdictionConfig        JurisdictionConfig?
  platformSubscription      PlatformSubscription?
  virtualOfficeAddresses    VirtualOfficeAddress[]
  virtualOfficeSubscriptions VirtualOfficeSubscription[]
  mailItems                 MailItem[]
  whatsAppConfig            WhatsAppConfig?
  whatsAppMessages          WhatsAppMessage[]
  whatsAppTemplates         WhatsAppTemplate[]
  whatsAppBroadcasts        WhatsAppBroadcast[]
  documents                 Document[]
  documentRequests          DocumentRequest[]
  deliveries                Delivery[]

  @@index([slug])
}

// ─── JURISDICTION CONFIG (GCC) ────────────────────────────────────────────────
// Per-organization jurisdiction settings. Drives VAT rates, currencies, and
// jurisdiction-specific toggles (ZATCA, Arabic invoices, WhatsApp). Always read
// jurisdiction-derived values via lib/jurisdiction.ts — never hardcode inline.

model JurisdictionConfig {
  id                  String         @id @default(cuid())
  organizationId      String         @unique
  jurisdictions       Jurisdiction[] @default([])   // ['UAE'], ['KSA'], or both
  primaryJurisdiction Jurisdiction   @default(UAE)
  vatRateUAE          Decimal        @default(0.05) @db.Decimal(5, 4)  // 5%
  vatRateKSA          Decimal        @default(0.15) @db.Decimal(5, 4)  // 15%
  currencyUAE         String         @default("AED")
  currencyKSA         String         @default("SAR")
  zatcaEnabled        Boolean        @default(false)  // KSA only
  arabicInvoices      Boolean        @default(false)
  whatsappEnabled     Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// Tracks the operator's CoWork Pro platform subscription (not member billing).
// Manual billing only — no payment gateway. Created at TRIAL on org registration.
model PlatformSubscription {
  id                   String                     @id @default(cuid())
  organizationId       String                     @unique
  status               PlatformSubscriptionStatus @default(TRIAL)
  plan                 Plan
  // Billing currency derived from org jurisdiction (UAE → AED, KSA → SAR).
  currency             String                     @default("AED")
  // Monthly fee in local currency — null until operator upgrades from trial.
  monthlyFee           Decimal?                   @db.Decimal(10, 2)
  // Stripe Atlas fields — reserved for future use
  stripeCustomerId     String?
  stripeSubscriptionId String?
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  organization         Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─── USERS & AUTH ─────────────────────────────────────────────────────────────
// Note: Supabase Auth manages authentication.
// This User model mirrors the Supabase auth.users table for relational data.

model User {
  id           String   @id // matches Supabase auth.users.id (UUID)
  email        String   @unique
  name         String?
  avatar       String?
  isSuperAdmin Boolean  @default(false)
  // Google Calendar integration
  googleCalendarRefreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organizations UserOrganization[]
  bookings      Booking[]
  member        Member?

  @@index([email])
}

model UserOrganization {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           UserRole     @default(MEMBER)
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

// ─── LOCATIONS ────────────────────────────────────────────────────────────────

model Location {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  address        String?
  floorPlanUrl   String?
  isActive       Boolean      @default(true)
  // Multi-location & franchise (Module 11)
  jurisdiction       Jurisdiction @default(UAE)
  city               String?
  country            String?
  timezone           String?    // overrides org timezone for this location
  phone              String?
  email              String?
  vatNumber          String?    // KSA requires per-branch VAT registration
  managerUserId      String?    // operator user who manages this location
  openingHours       Json?      // { mon: { open, close, closed }, ... }
  accessInstructions String?    // shown to members (how to get in)
  wifiName           String?
  wifiPassword       String?    // encrypted at rest (lib/encryption.ts)
  parentLocationId   String?    // franchise sub-location → parent
  deletedAt          DateTime?  // soft delete
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  resources      Resource[]

  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([organizationId, deletedAt])
}

// ─── RESOURCES ────────────────────────────────────────────────────────────────

model Resource {
  id                  String       @id @default(cuid())
  organizationId      String
  locationId          String
  name                String
  type                ResourceType
  description         String?
  capacity            Int          @default(1)
  hourlyRate          Decimal?     @db.Decimal(10, 2)
  halfDayRate         Decimal?     @db.Decimal(10, 2)
  fullDayRate         Decimal?     @db.Decimal(10, 2)
  amenities           String[]
  images              String[]
  isActive            Boolean      @default(true)
  requiresApproval    Boolean      @default(false)
  advanceBookingDays  Int          @default(30)
  minBookingMinutes   Int          @default(30)
  maxBookingHours     Int          @default(8)
  // Soft delete
  deletedAt           DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location       Location     @relation(fields: [locationId], references: [id])
  bookings       Booking[]

  @@index([organizationId])
  @@index([locationId])
  @@index([organizationId, deletedAt])
}

// ─── MEMBERSHIP PLANS ─────────────────────────────────────────────────────────

model MembershipPlan {
  id              String       @id @default(cuid())
  organizationId  String
  name            String
  description     String?
  type            PlanType
  price           Decimal      @db.Decimal(10, 2)
  billingCycle    BillingCycle @default(MONTHLY)
  includedCredits Int          @default(0)
  meetingRoomHours Int         @default(0)
  features        String[]
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        Member[]

  @@index([organizationId])
}

// ─── MEMBERS ─────────────────────────────────────────────────────────────────

model Member {
  id               String         @id @default(cuid())
  organizationId   String
  userId           String         @unique
  membershipPlanId String?
  status           MemberStatus   @default(ACTIVE)
  startDate        DateTime       @default(now())
  endDate          DateTime?
  credits          Int            @default(0)
  notes            String?
  company          String?
  jobTitle         String?
  bio              String?
  phone            String?
  // GCC fields
  whatsAppNumber   String?        // WhatsApp number for automated messaging
  nationality      String?        // ISO country code or name
  passportNumber   String?        // Encrypted at rest via lib/encryption.ts
  emiratesId       String?        // UAE Emirates ID — encrypted at rest
  iqamaNumber      String?        // KSA Iqama number — encrypted at rest
  visaExpiry       DateTime?      // Visa/residency expiry — drives renewal reminders
  // Soft delete
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  organization              Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                      User            @relation(fields: [userId], references: [id])
  membershipPlan            MembershipPlan? @relation(fields: [membershipPlanId], references: [id])
  bookings                  Booking[]
  invoices                  Invoice[]
  virtualOfficeSubscriptions VirtualOfficeSubscription[]
  whatsAppMessages          WhatsAppMessage[]
  documents                 Document[]
  documentRequests          DocumentRequest[]
  deliveries                Delivery[]

  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, status])
}

// ─── BOOKINGS ────────────────────────────────────────────────────────────────

model Booking {
  id               String        @id @default(cuid())
  organizationId   String
  resourceId       String
  memberId         String?
  userId           String
  title            String?
  description      String?
  startTime        DateTime
  endTime          DateTime
  status           BookingStatus @default(CONFIRMED)
  creditsUsed      Int           @default(0)
  amountCharged    Decimal       @default(0) @db.Decimal(10, 2)
  invoiceId        String?       // set when booking is added to an invoice
  attendees        Int           @default(1)
  externalGuests   String[]
  checkedInAt      DateTime?
  checkedOutAt     DateTime?
  cancelledAt      DateTime?
  cancelReason     String?
  isRecurring      Boolean       @default(false)
  recurringGroupId String?
  // Google Calendar
  googleCalendarEventId String?
  // Soft delete
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  resource       Resource     @relation(fields: [resourceId], references: [id])
  member         Member?      @relation(fields: [memberId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  invoice        Invoice?     @relation(fields: [invoiceId], references: [id])

  @@index([organizationId])
  @@index([resourceId])
  @@index([memberId])
  @@index([organizationId, startTime, endTime])
  @@index([resourceId, status])
  @@index([organizationId, status])
  @@index([organizationId, deletedAt])
}

// ─── INVOICES ────────────────────────────────────────────────────────────────

model Invoice {
  id              String        @id @default(cuid())
  organizationId  String
  memberId        String
  invoiceNumber   String?       // e.g. INV-2024-001
  // @deprecated — Stripe no longer used for member billing (use tapChargeId)
  stripeInvoiceId String?
  // @deprecated — Stripe no longer used for member billing
  stripePaymentLinkId String?
  tapChargeId     String?       // Tap payment gateway charge ID (GCC primary)
  // @deprecated — superseded by the subtotal/vatAmount/totalAmount breakdown
  // below. Retained for transition + backfill; kept equal to `totalAmount`.
  // Do not read for new code — use `totalAmount`.
  amount          Decimal       @db.Decimal(10, 2)
  // VAT-compliant money breakdown (GCC). subtotal is VAT-exclusive; VAT is
  // applied on top per the org's jurisdiction; totalAmount = subtotal + vatAmount.
  subtotal        Decimal       @default(0) @db.Decimal(10, 2)
  vatRate         Decimal       @default(0) @db.Decimal(5, 4)  // e.g. 0.05 UAE, 0.15 KSA
  vatAmount       Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal       @default(0) @db.Decimal(10, 2)
  currency        String        @default("AED")
  status          InvoiceStatus @default(DRAFT)
  dueDate         DateTime
  paidAt          DateTime?
  periodStart     DateTime?
  periodEnd       DateTime?
  lineItems       Json          // [{ description, quantity, unitPrice, total }]
  notes           String?
  virtualOfficeSubscriptionId String?
  // ZATCA e-invoicing (KSA only — null for UAE / non-VAT invoices)
  zatcaUuid       String?       // invoice UUID (Phase 2)
  zatcaHash       String?       // invoice hash / PIH placeholder
  zatcaQrCode     String?       // Phase-1 TLV QR, base64 (ZATCA-compliant)
  zatcaStatus     ZatcaStatus?
  zatcaReportedAt DateTime?
  // Soft delete
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization              Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member                    Member                     @relation(fields: [memberId], references: [id])
  bookings                  Booking[]
  virtualOfficeSubscription VirtualOfficeSubscription? @relation(fields: [virtualOfficeSubscriptionId], references: [id])

  @@index([organizationId])
  @@index([memberId])
  @@index([organizationId, status])
  @@index([dueDate])
  @@index([organizationId, deletedAt])
}

// ─── VISITORS ────────────────────────────────────────────────────────────────

model Visitor {
  id              String    @id @default(cuid())
  organizationId  String
  name            String
  email           String?
  phone           String?
  company         String?
  hostMemberId    String?
  purpose         String?
  expectedArrival DateTime?
  checkedInAt     DateTime?
  checkedOutAt    DateTime?
  // GCC / reception (Module 9)
  nationality     String?
  idType          String?   // "Passport" | "Emirates ID" | "Iqama"
  idNumber        String?   // encrypted at rest (lib/encryption.ts)
  vehiclePlate    String?
  photoUrl        String?   // private bucket object path — served via signed URL
  isBlacklisted   Boolean   @default(false)
  blacklistReason String?
  whatsappNotified Boolean  @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, checkedInAt])
  @@index([organizationId, deletedAt])
  @@index([organizationId, isBlacklisted])
}

// ─── DELIVERIES (reception) ─────────────────────────────────────────────────
// Packages/mail received at reception for members (distinct from the Virtual
// Office mailroom, which is for registered-address clients).

model Delivery {
  id             String    @id @default(cuid())
  organizationId String
  memberId       String?
  courierName    String?
  trackingNumber String?
  description    String?
  photoUrl       String?
  receivedBy     String?   // staff name
  receivedAt     DateTime  @default(now())
  notifiedAt     DateTime?
  collectedAt    DateTime?
  collectedBy    String?   // who collected (name / signature note)
  whatsappNotified Boolean @default(false)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member         Member?      @relation(fields: [memberId], references: [id])

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, collectedAt])
  @@index([memberId])
}

// ─── COMMUNITY ───────────────────────────────────────────────────────────────

model Announcement {
  id             String       @id @default(cuid())
  organizationId String
  title          String
  body           String
  isPinned       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Event {
  id             String       @id @default(cuid())
  organizationId String
  title          String
  description    String?
  startTime      DateTime
  endTime        DateTime
  location       String?
  capacity       Int?
  imageUrl       String?
  isPublic       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, startTime])
}

// ─── VIRTUAL OFFICE ───────────────────────────────────────────────────────────

model VirtualOfficeAddress {
  id             String             @id @default(cuid())
  organizationId String
  jurisdiction   Jurisdiction       @default(UAE)
  addressLine    String
  addressType    VirtualAddressType @default(MAINLAND)
  freezoneName   String?            // e.g. "DMCC", "DIFC", "ADGM"
  ejariNumber    String?            // UAE: Ejari contract reference
  maxClients     Int                @default(50)
  isActive       Boolean            @default(true)
  monthlyFee     Decimal            @db.Decimal(10, 2)
  // Soft delete
  deletedAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptions  VirtualOfficeSubscription[]
  mailItems      MailItem[]

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, isActive])
}

model VirtualOfficeSubscription {
  id             String              @id @default(cuid())
  organizationId String
  memberId       String
  addressId      String
  companyName    String
  licenseNumber  String?
  licenseExpiry  DateTime?
  startDate      DateTime            @default(now())
  endDate        DateTime?
  renewalDate    DateTime?
  status         VirtualOfficeStatus @default(ACTIVE)
  monthlyFee     Decimal             @db.Decimal(10, 2)
  currency       String              @default("AED")
  notes          String?
  // Soft delete — KSA ZATCA mandates 5-year retention; never hard delete
  deletedAt      DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member         Member               @relation(fields: [memberId], references: [id])
  address        VirtualOfficeAddress @relation(fields: [addressId], references: [id])
  invoices       Invoice[]
  mailItems      MailItem[]

  @@index([organizationId])
  @@index([memberId])
  @@index([addressId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, status])
}

model MailItem {
  id             String                     @id @default(cuid())
  organizationId String
  addressId      String
  subscriptionId String?
  senderName     String?
  senderAddress  String?
  receivedAt     DateTime                   @default(now())
  mailType       MailType                   @default(OTHER)
  description    String?
  trackingNumber String?
  // scanUrl: Supabase Storage object path (not a URL); signed URL generated on read
  scanPath       String?
  forwardedAt    DateTime?
  forwardedTo    String?
  notifiedAt     DateTime?
  collectedAt    DateTime?
  // Soft delete
  deletedAt      DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  organization   Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  address        VirtualOfficeAddress        @relation(fields: [addressId], references: [id])
  subscription   VirtualOfficeSubscription?  @relation(fields: [subscriptionId], references: [id])

  @@index([organizationId])
  @@index([addressId])
  @@index([subscriptionId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, receivedAt])
}

// ─── WHATSAPP BUSINESS API ────────────────────────────────────────────────────
// Per-org WhatsApp Business API credentials. accessToken is encrypted at rest via
// lib/encryption.ts. Falls back to platform-level env vars when no row exists.

model WhatsAppConfig {
  id                String   @id @default(cuid())
  organizationId    String   @unique
  phoneNumberId     String
  accessToken       String   // encrypted at rest (lib/encryption.ts)
  businessAccountId String
  verifyToken       String   // webhook verification challenge token
  displayNumber     String?  // human-readable sender number, e.g. +971 50 000 0000
  isActive          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model WhatsAppMessage {
  id                String              @id @default(cuid())
  organizationId    String
  memberId          String?
  broadcastId       String?
  phone             String              // E.164, no + (Meta format)
  direction         MessageDirection
  messageType       WhatsAppMessageType @default(CUSTOM)
  templateName      String?
  content           String
  mediaUrl          String?
  waMessageId       String?             // Meta message ID (wamid.*)
  status            WhatsAppStatus      @default(SENT)
  sentAt            DateTime            @default(now())
  deliveredAt       DateTime?
  readAt            DateTime?
  failedReason      String?
  relatedEntityType String?             // "booking" | "invoice" | "proservice" ...
  relatedEntityId   String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member            Member?             @relation(fields: [memberId], references: [id])
  broadcast         WhatsAppBroadcast?  @relation(fields: [broadcastId], references: [id])

  @@index([organizationId])
  @@index([memberId])
  @@index([organizationId, status])
  @@index([organizationId, phone])
  @@index([organizationId, sentAt])
  @@index([broadcastId])
  @@index([waMessageId])
}

// Reusable message templates. Mirrors Meta-approved templates plus locally-drafted
// quick replies. Body uses {{1}}, {{2}} positional placeholders (Meta convention).
model WhatsAppTemplate {
  id             String                   @id @default(cuid())
  organizationId String
  name           String                   // Meta template name (snake_case)
  category       WhatsAppTemplateCategory @default(UTILITY)
  language       String                   @default("en")
  body           String
  variables      String[]                 @default([])  // labels for {{1}}, {{2}} ...
  status         WhatsAppTemplateStatus   @default(DRAFT)
  isActive       Boolean                  @default(true)
  deletedAt      DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([organizationId, deletedAt])
}

// A one-to-many broadcast campaign. Each broadcast fans out into WhatsAppMessage
// rows (one per recipient) linked via broadcastId.
model WhatsAppBroadcast {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  templateName   String?         // template used, if any
  content        String          // resolved/preview body
  audienceFilter Json?           // { status?, membershipPlanId?, hasWhatsApp? }
  status         BroadcastStatus @default(DRAFT)
  recipientCount Int             @default(0)
  sentCount      Int             @default(0)
  failedCount    Int             @default(0)
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages       WhatsAppMessage[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, deletedAt])
}

// ─── DOCUMENT VAULT ───────────────────────────────────────────────────────────
// Per-member document storage. Files live in a PRIVATE Supabase bucket; fileUrl
// holds the storage object PATH, never a public URL. Served only via short-lived
// (15-min) signed URLs generated on demand. documentNumber is encrypted at rest.

model Document {
  id                String       @id @default(cuid())
  organizationId    String
  memberId          String
  documentType      DocumentType
  label             String?      // free-text label, esp. for OTHER
  fileUrl           String       // private bucket object path (NOT a public URL)
  fileName          String
  fileSize          Int
  mimeType          String
  expiryDate        DateTime?
  issueDate         DateTime?
  issueCountry      String?
  documentNumber    String?      // encrypted at rest (lib/encryption.ts)
  isVerified        Boolean      @default(false)
  verifiedAt        DateTime?
  verifiedBy        String?      // operator userId who verified
  notes             String?
  version           Int          @default(1)
  previousVersionId String?      // chain to the prior version of this document
  uploadedBy        String?      // userId who uploaded (member or operator)
  uploadedAt        DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?    // soft delete (also used to retire old versions)

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member            Member       @relation(fields: [memberId], references: [id])

  @@index([organizationId])
  @@index([memberId])
  @@index([organizationId, expiryDate])
  @@index([organizationId, deletedAt])
  @@index([memberId, deletedAt])
}

model DocumentRequest {
  id             String                @id @default(cuid())
  organizationId String
  memberId       String
  requestedBy    String                // operator userId
  documentType   DocumentType
  message        String?
  dueDate        DateTime?
  status         DocumentRequestStatus @default(PENDING)
  fulfilledAt    DateTime?
  fulfilledDocId String?               // Document.id that fulfilled the request
  deletedAt      DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member         Member       @relation(fields: [memberId], references: [id])

  @@index([organizationId])
  @@index([memberId])
  @@index([organizationId, status])
  @@index([memberId, status])
}
